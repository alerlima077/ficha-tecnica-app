{
  "version": 2,
  "name": "ficha-tecnica-app",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "pages/**",
      "use": "@vercel/static"
    },
    {
      "src": "src/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/insumos",
      "dest": "/pages/insumos.html"
    },
    {
      "src": "/ficha-tecnica",
      "dest": "/pages/ficha-tecnica.html"
    },
    {
      "src": "/pre-preparo",
      "dest": "/pages/pre-preparo.html"
    },
    {
      "src": "/cardapio",
      "dest": "/pages/cardapio.html"
    },
    {
      "src": "/setor-pizzaria",
      "dest": "/pages/setor-pizzaria.html"
    },
    {
      "src": "/setor-restaurante",
      "dest": "/pages/setor-restaurante.html"
    },
    {
      "src": "/setor-padaria",
      "dest": "/pages/setor-padaria.html"
    },
    {
      "src": "/src/(.*)",
      "dest": "/src/$1"
    }
  ]
}